[Unit]
Description=Insider Tracker — PostgreSQL backup to DigitalOcean Spaces
After=network.target

[Service]
Type=oneshot
User=deploy
WorkingDirectory=/home/deploy/insider-tracker
ExecStart=/home/deploy/insider-tracker/.venv/bin/python /home/deploy/insider-tracker/scripts/backup_postgres.py
EnvironmentFile=-/home/deploy/insider-tracker/.env
StandardOutput=journal
StandardError=journal
