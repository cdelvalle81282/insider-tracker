[Unit]
Description=Insider Tracker — Update last_close prices from Polygon
After=network.target

[Service]
Type=oneshot
User=deploy
WorkingDirectory=/home/deploy/insider-tracker
EnvironmentFile=-/home/deploy/insider-tracker/.env
ExecStart=/home/deploy/insider-tracker/.venv/bin/python ingest.py --update-prices
StandardOutput=journal
StandardError=journal
